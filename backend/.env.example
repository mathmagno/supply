# ── Banco de dados (Supabase PostgreSQL) ───────────────────────────────────
# Formato: postgresql://usuario:senha@host:5432/nome_banco
DATABASE_URL=postgresql+pg8000://postgres:suasenha@db.supabase.co:5432/postgres

# ── JWT ────────────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=troque_por_uma_chave_secreta_forte
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=480

# ── Storage S3 (para os arquivos .xlsx) ────────────────────────────────────
STORAGE_BUCKET=supply-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── CORS (separe múltiplas origens por vírgula) ────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
